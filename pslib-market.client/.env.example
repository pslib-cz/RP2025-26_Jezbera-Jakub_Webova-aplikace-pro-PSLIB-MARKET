# OIDC
VITE_OIDC_AUTHORITY=https://oauth.pslib.cz
VITE_OIDC_CLIENT_ID=market
VITE_OIDC_REDIRECT_URI=http://localhost:51572/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:51572/

# API
# Keep /api for production when frontend and backend are behind the same host.
VITE_API_BASE_URL=/api

# Development only: Vite dev server proxy target.
VITE_API_PROXY_TARGET=http://localhost:5263
